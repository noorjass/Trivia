    // Shuffle for variety
    for (let i = QUESTIONS.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [QUESTIONS[i], QUESTIONS[j]] = [QUESTIONS[j], QUESTIONS[i]];
    }

    // Game state
    let currentIndex = 0;
    let currentQuestion = QUESTIONS[0];
    let stealMode = false;
    let awaitingAnswer = true;
    let lastPassingTeam = null;
    let scoreA = 0, scoreB = 0;
    let hostMode = false;
    
    const categoryTag = document.getElementById('categoryTag');
    const questionText = document.getElementById('questionText');
    const optionsContainer = document.getElementById('optionsContainer');
    const feedbackMsg = document.getElementById('feedbackMsg');
    const answerRevealDiv = document.getElementById('answerReveal');
    const passBtn = document.getElementById('passBtn');
    const nextBtn = document.getElementById('nextBtn');
    const resetGameBtn = document.getElementById('resetGameBtn');
    const revealBtn = document.getElementById('revealBtn');
    const printBtn = document.getElementById('printCardsBtn');
    const hostToggle = document.getElementById('hostModeToggle');
    const hostBadge = document.getElementById('hostBadge');
    const scoreElA = document.getElementById('scoreA');
    const scoreElB = document.getElementById('scoreB');

    function updateScoresUI() {
        scoreElA.innerText = scoreA;
        scoreElB.innerText = scoreB;
    }

    function addPoints(team, points) {
        if (team === 'A') scoreA += points;
        else scoreB += points;
        updateScoresUI();
    }

    function updateHostMode() {
        hostMode = hostToggle.checked;
        if (hostMode) {
            hostBadge.innerText = 'ON';
            hostBadge.style.background = '#ff66b5';
            hostBadge.style.color = 'white';
        } else {
            hostBadge.innerText = 'OFF';
            hostBadge.style.background = '#ffb6d9';
            hostBadge.style.color = '#b33b6e';
            answerRevealDiv.style.display = 'none';
        }
    }

    function revealAnswer() {
        answerRevealDiv.innerHTML = `💖 ANSWER: ${currentQuestion.correct} 💖`;
        answerRevealDiv.style.display = 'block';
        if (!hostMode) {
            setTimeout(() => {
                if (!hostMode) answerRevealDiv.style.display = 'none';
            }, 5000);
        }
    }

    function loadQuestion() {
        currentQuestion = QUESTIONS[currentIndex];
        categoryTag.innerText = currentQuestion.category;
        questionText.innerText = currentQuestion.text;
        
        optionsContainer.innerHTML = '';
        answerRevealDiv.style.display = 'none';
        
        if (currentQuestion.options && currentQuestion.options.length > 0) {
            const optionsDiv = document.createElement('div');
            optionsDiv.className = 'options-area';
            currentQuestion.options.forEach((opt, idx) => {
                const letter = String.fromCharCode(65+idx);
                const optDiv = document.createElement('div');
                optDiv.className = 'opt-item';
                optDiv.innerHTML = `<span class="opt-prefix">${letter}</span><span>${opt}</span>`;
                optDiv.addEventListener('click', () => handleAnswer(letter));
                optionsDiv.appendChild(optDiv);
            });
            optionsContainer.appendChild(optionsDiv);
        } else {
            const noOptDiv = document.createElement('div');
            noOptDiv.className = 'no-options';
            noOptDiv.innerHTML = '🎀 OPEN ANSWER — Team answers verbally, then host awards points! 🎀';
            optionsContainer.appendChild(noOptDiv);
        }
        
        awaitingAnswer = true;
        stealMode = false;
        passBtn.disabled = false;
        feedbackMsg.innerHTML = "💖 Team picks answer or PASS to give steal chance (0.5pt) 💖";
    }

    function handleAnswer(selectedLetter) {
        if (!awaitingAnswer) {
            feedbackMsg.innerHTML = "⏳ Already answered! Click NEXT for new question.";
            return;
        }
        
        if (!currentQuestion.options) {
            feedbackMsg.innerHTML = `📢 Open answer! Correct answer: "${currentQuestion.correct}". Use +/- buttons to award points.`;
            awaitingAnswer = false;
            passBtn.disabled = true;
            if (hostMode) revealAnswer();
            return;
        }
        
        const isCorrect = (selectedLetter === currentQuestion.correct);
        
        if (isCorrect) {
            if (stealMode && lastPassingTeam) {
                const stealingTeam = lastPassingTeam === 'A' ? 'B' : 'A';
                feedbackMsg.innerHTML = `🔥 STEAL SUCCESS! Team ${stealingTeam} gets 0.5 points! Answer: ${currentQuestion.correct}. Use +/- buttons.`;
            } else if (!stealMode) {
                feedbackMsg.innerHTML = `✅ CORRECT! +1 point for answering team! Answer: ${currentQuestion.correct}. Use +/- buttons.`;
            }
            if (hostMode) revealAnswer();
            awaitingAnswer = false;
            passBtn.disabled = true;
        } else {
            feedbackMsg.innerHTML = `❌ WRONG! Correct answer: ${currentQuestion.correct}. Other team can attempt steal next round.`;
            if (hostMode) revealAnswer();
            awaitingAnswer = false;
            passBtn.disabled = true;
        }
    }

    passBtn.addEventListener('click', () => {
        if (!awaitingAnswer) {
            feedbackMsg.innerHTML = "Already answered! Can't PASS now.";
            return;
        }
        
        const teamPass = confirm("Which team is passing?\nOK = Team GLITTER passes\nCancel = Team SPARKLE passes");
        if (teamPass) {
            lastPassingTeam = 'A';
            feedbackMsg.innerHTML = "🚨 TEAM GLITTER PASSED! Team SPARKLE gets STEAL chance for 0.5 points! Pick an answer! 🚨";
        } else {
            lastPassingTeam = 'B';
            feedbackMsg.innerHTML = "🚨 TEAM SPARKLE PASSED! Team GLITTER gets STEAL chance for 0.5 points! Pick an answer! 🚨";
        }
        stealMode = true;
        passBtn.disabled = true;
    });

    revealBtn.addEventListener('click', () => {
        revealAnswer();
    });

    nextBtn.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % QUESTIONS.length;
        loadQuestion();
    });

    resetGameBtn.addEventListener('click', () => {
        scoreA = 0;
        scoreB = 0;
        updateScoresUI();
        currentIndex = 0;
        loadQuestion();
