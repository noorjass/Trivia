            addPoints(team, points);
        });
    });

    hostToggle.addEventListener('change', updateHostMode);

    printBtn.addEventListener('click', () => {
        let printHtml = `<html><head><title>Love Shack Trivia - 200 Cards</title><style>
            body{font-family:'Poppins',sans-serif; padding:20px; background:#ffeef5;}
            .card{page-break-after:always; border:2px solid #ffb6d9; border-radius:32px; padding:24px; margin-bottom:20px; background:#fffaf5;}
            .front{background:#fff9f5;}
            .back{background:#fff5ee;}
            h3{color:#cc3388;} .answer{font-size:1.2rem; font-weight:bold; color:#b33b6e;}
            .category{background:#ffd9b5; display:inline-block; padding:4px 16px; border-radius:40px; font-size:0.7rem;}
            hr{border-color:#ffccaa;}
        </style></head><body>`;
        
        QUESTIONS.forEach((q, idx) => {
            printHtml += `<div class="card front">
                <div class="category">💖 ${q.category}</div>
                <h3>Card ${idx+1}/200</h3>
                <p style="font-size:1.3rem; font-weight:600; color:#4a2a38;">${q.text}</p>
                ${q.options ? `<div style="margin:12px 0;"><strong>Options:</strong><br>${q.options.map(o => `• ${o}`).join('<br>')}</div>` : '<em style="color:#cc88a2;">🎀 Open-ended question — no options given</em>'}
                <hr>
                <p style="color:#cc88a2;">✨ FLIP FOR ANSWER ✨</p>
            </div>`;
            printHtml += `<div class="card back">
                <div class="category">✅ ANSWER</div>
                <h3>Card ${idx+1} (Back)</h3>
                <p class="answer">${q.correct}</p>
                <p style="color:#cc88a2;">💖 Love Shack Trivia - Stanley Cup Vibes 💖</p>
            </div>`;
        });
        printHtml += `</body></html>`;
        const win = window.open();
        win.document.write(printHtml);
        win.document.close();
        win.print();
    });

    loadQuestion();
    updateScoresUI();
    updateHostMode();
</script>
